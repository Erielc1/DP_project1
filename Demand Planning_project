   "metadata": {},
   "outputs": [],
   "source": [
    "import pandas as pd\n",
    "df = pd.read_csv(\"product demand/Historical Product Demand.csv\", parse_dates=[\"Date\"])\n",
    "df['Order_Demand'] = pd.to_numeric(df['Order_Demand'], errors='coerce')\n",
    "df = df[df['Order_Demand'] >= 0].dropna(subset=['Order_Demand', 'Date'])\n",
    "df = df.sort_values(['Product_Code', \"Date\"]).reset_index(drop=True)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 5,
   "id": "71d049f3-86f1-444e-9686-cdb0b6c8e1ae",
   "metadata": {},
   "outputs": [],
   "source": [
    "grouped = df.groupby(\"Product_Code\")[\"Order_Demand\"]\n",
    "\n",
    "df[\"lag_1\"] = grouped.shift(1)\n",
    "df[\"lag_2\"] = grouped.shift(2)\n",
    "df[\"lag_3\"] = grouped.shift(3)\n",
    "df[\"roll_mean_3\"] = grouped.shift(1).rolling(3).mean().reset_index(level=0, drop=True)\n",
    "df[\"roll_mean_7\"] = grouped.shift(1).rolling(7).mean().reset_index(level=0, drop=True)\n",
    "df[\"roll_std_3\"] = grouped.shift(1).rolling(3).std().reset_index(level=0, drop=True)"
   ]
  },
  {
   "cell_type": "code",
