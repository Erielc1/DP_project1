    "else:\n",
    "    print(f\"{data_path} doesn't exist, creating one...\")\n",
    "    data_path.mkdir(parents=True, exist_ok=True)\n",
    "\n",
    "#Unzip\n",
    "with zipfile.ZipFile(\"archive.zip\", \"r\")as zip_ref:\n",
